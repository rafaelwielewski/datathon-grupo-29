# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=datathon-grupo-29

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM — GitHub Models (gratuito com GitHub Copilot)
# Gerar em: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=github_pat_...

# Alternativa: OpenAI direta
# OPENAI_API_KEY=sk-...

# DVC remote (opcional — para versionamento remoto)
# DVC_REMOTE_URL=s3://meu-bucket/datathon
