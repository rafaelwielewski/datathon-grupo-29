# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlruns.db
MLFLOW_EXPERIMENT_NAME=datathon-grupo-29

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM — Ollama (local, sem API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# DVC remote (opcional — para versionamento remoto)
# DVC_REMOTE_URL=s3://meu-bucket/datathon
