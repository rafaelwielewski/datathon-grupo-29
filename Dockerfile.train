FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
RUN pip install --no-cache-dir -e "." --timeout 120

COPY src/ ./src/
COPY configs/ ./configs/

ENV PYTHONPATH=/app

CMD ["python", "src/models/train.py"]
